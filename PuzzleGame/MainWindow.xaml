<Window x:Class="PuzzleGame.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PuzzleGame"
        Title="Паззл" Height="600" Width="500"
        MinHeight="400" MinWidth="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        UseLayoutRounding="True"
        Background="#FFF4F4F8">

    <Window.DataContext>
        <local:GameViewModel />
    </Window.DataContext>

    <Window.Resources>
        <local:CellIndexToPixelConverter x:Key="CellToPixel" />
        <!-- Встроенный в WPF конвертер bool -> Visibility, чтобы прятать/показывать
             меню и игровое поле без написания своего кода. -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <!-- Общий стиль для кнопок, чтобы не повторять одни и те же
             настройки внешнего вида в каждой кнопке отдельно. -->
        <Style x:Key="MainButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="#FF4A6FA5" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3C5C89" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>

        <!-- ===================== СТАРТОВОЕ МЕНЮ ===================== -->
        <Grid Visibility="{Binding IsMenuVisible, Converter={StaticResource BoolToVisibility}}"
              Background="#FFF4F4F8">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Паззл"
                           FontSize="40" FontWeight="Bold"
                           Foreground="#FF2E2E2E"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30" />

                <Button Content="Играть"
                        Command="{Binding StartGameCommand}"
                        Style="{StaticResource MainButtonStyle}"
                        FontSize="18"
                        Padding="40,12"
                        HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- ===================== ИГРОВОЙ ЭКРАН ===================== -->
        <Grid Margin="10"
              Visibility="{Binding IsGameVisible, Converter={StaticResource BoolToVisibility}}">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <TextBlock Grid.Row="0"
                       Text="Паззл"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#FF2E2E2E"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />

            <!-- Панель управления -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,10">
                <Button Content="Новая игра"
                        Command="{Binding NewGameCommand}"
                        Style="{StaticResource MainButtonStyle}"
                        Margin="0,0,20,0" />
                <TextBlock Text="Ходов: " VerticalAlignment="Center" />
                <TextBlock Text="{Binding MoveCount}" VerticalAlignment="Center" FontWeight="Bold" />
            </StackPanel>

            <!-- Игровое поле с Viewbox (масштабирование вместе с окном) -->
            <Viewbox Grid.Row="2"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     UseLayoutRounding="True">
                <Border BorderBrush="#FF4A6FA5" BorderThickness="3"
                        Width="382" Height="218"
                        SnapsToDevicePixels="True">

                    <ItemsControl ItemsSource="{Binding Tiles}" x:Name="TilesItemsControl">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas Width="380" Height="216" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left"
                                        Value="{Binding Column, Converter={StaticResource CellToPixel}, ConverterParameter=95}" />
                                <Setter Property="Canvas.Top"
                                        Value="{Binding Row, Converter={StaticResource CellToPixel}, ConverterParameter=54}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="93" Height="52" Margin="1"
                                        BorderBrush="#FF8A8A8A" BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                                                    <Setter Property="Visibility" Value="Hidden" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsEmpty}" Value="False">
                                                    <Setter Property="Cursor" Value="Hand" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.TileClickCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}" />
                                    </Border.InputBindings>

                                    <Image Source="{Binding ImagePath}" Stretch="Fill"
                                           RenderOptions.BitmapScalingMode="HighQuality" />
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </Viewbox>

            <!-- Статусная строка -->
            <TextBlock Grid.Row="3"
                       Text="{Binding StatusMessage}"
                       FontSize="14" FontStyle="Italic"
                       Foreground="#FF555555"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0" />
        </Grid>

    </Grid>
</Window>
